REACT_APP_AUTH_URL=http://localhost:8001
REACT_APP_MEMBER_URL=http://localhost:8002
REACT_APP_RECRUITER_URL=http://localhost:8003
REACT_APP_JOB_URL=http://localhost:8004
REACT_APP_APP_URL=http://localhost:8005
REACT_APP_MSG_URL=http://localhost:8006
REACT_APP_ANALYTICS_URL=http://localhost:8007
REACT_APP_AI_URL=http://localhost:8008
CACHE_MODE=redis
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# Docker Compose reads this for the mysql service (root) and for every app service’s MYSQL_PASSWORD.
# Host scripts / pytest use MYSQL_PASSWORD below — keep the two passwords identical for local dev.
# If MySQL was already initialized with a different root password, recreate the volume after changing:
#   docker compose down && docker volume rm "$(docker volume ls -q | grep -E 'mysql|linkedin' | head -1)"
MYSQL_ROOT_PASSWORD=root
# Host→container MySQL mapping (default 3306). Use 3307 if you run Homebrew MySQL on 3306.
MYSQL_PUBLISH_PORT=3306
# Grafana UI on host (default 3000). If 3000/3001 are busy, try 3030 or 3100.
GRAFANA_PUBLISH_PORT=3000

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=linkedin_sim
MYSQL_USER=root
MYSQL_PASSWORD=root
MONGO_URL=mongodb://mongo:27017
MONGO_DATABASE=linkedin_sim_docs
JWT_ISSUER=owner1-auth
JWT_AUDIENCE=linkedin-clone
OWNER1_JWKS_URL=http://auth_service:8001/.well-known/jwks.json

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
PUBLIC_BASE_URL=

MESSAGING_SERVICE_URL=http://messaging_connections_service:8006

AI_KAFKA_CONSUMERS_ENABLED=true

# applications_service: POST /applications/submit publishes application.submit.requested first, then worker persists (Docker default true).
APPLICATION_SUBMIT_KAFKA_FIRST=true

# --- Person 3: bulk data (optional) ---
# After schema is applied, from the repo root with MYSQL_* pointing at your DB:
#   python3 scripts/load_kaggle_datasets.py --jobs-csv /path/to/jobs.csv --resumes-csv /path/to/resumes.csv --max-jobs 10000 --max-members 5000
# Or synthetic rows (no Kaggle files):
#   python3 scripts/load_kaggle_datasets.py --synthetic --max-jobs 10000 --max-members 5000
#   # Kaggle Resume.csv has ~2.5k usable rows; pad to 5k+ unique members:
#   python3 scripts/load_kaggle_datasets.py --synthetic-members-extra 2600 --chunk-size 400
#
# Imported jobs are owned by recruiter_id rec_kaggle_import. To see them in Recruiter dashboard + charts,
# sign in as:  bulk-kaggle-recruiter@example.com  password KaggleImport#2026
# (If you imported before: python3 scripts/ensure_bulk_import_login.py — from host use MYSQL_HOST=127.0.0.1 MYSQL_PORT=$MYSQL_PUBLISH_PORT)
# Restart Docker services after code changes so auth + jobs services pick up updates.
#
# Host API tests (quieter): ./scripts/run_api_tests_host.sh -q --disable-warnings

MINIO_PUBLIC_ENDPOINT=localhost:9000

# member_profile_service: signed GET /members/media URLs (profile photos). Match your browser’s member API base (LAN: http://<host>:8002).
MEMBER_PUBLIC_URL=http://localhost:8002
# Optional; defaults to JWT-related secret in dev. Set a long random string in production.
MEDIA_SIG_SECRET=
