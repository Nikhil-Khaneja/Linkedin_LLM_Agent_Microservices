# ── Database (MySQL) ──────────────────────────────────────────
# Inside Docker Compose the host is "mysql".
# For local development outside Docker, use "localhost" and port 3307.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=application_core
DB_USER=app_user
DB_PASSWORD=app_password

# ── Redis ─────────────────────────────────────────────────────
# Inside Docker Compose the host is "redis".
# For local development outside Docker, use "localhost" and port 6385.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_IDEMPOTENCY_TTL_SECONDS=86400

# ── Kafka ─────────────────────────────────────────────────────
# Owner 7 hosts the shared Kafka broker.
# Replace OWNER7_PUBLIC_DNS with the actual EC2 public DNS when integrating.
# Example: ec2-1-2-3-4.compute-1.amazonaws.com:9092
KAFKA_BOOTSTRAP_SERVERS=OWNER7_PUBLIC_DNS:9092

# ── Demo / standalone mode ────────────────────────────────────
# true  = allow applying to jobs not yet in job_status_projection (standalone demo)
# false = block unknown job IDs (final team integration mode)
DEMO_ALLOW_UNKNOWN_JOB=true
