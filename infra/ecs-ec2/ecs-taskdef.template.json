{
  "family": "linkedin-sim-all",
  "networkMode": "bridge",
  "requiresCompatibilities": [
    "EC2"
  ],
  "executionRoleArn": "arn:aws:iam::__AWS_ACCOUNT_ID__:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::__AWS_ACCOUNT_ID__:role/linkedinSimTaskRole",
  "volumes": [
    {
      "name": "mysql-data",
      "host": {
        "sourcePath": "/ecs/linkedin-sim/mysql"
      }
    },
    {
      "name": "mongo-data",
      "host": {
        "sourcePath": "/ecs/linkedin-sim/mongo"
      }
    },
    {
      "name": "redis-data",
      "host": {
        "sourcePath": "/ecs/linkedin-sim/redis"
      }
    },
    {
      "name": "kafka-data",
      "host": {
        "sourcePath": "/ecs/linkedin-sim/kafka"
      }
    },
    {
      "name": "minio-data",
      "host": {
        "sourcePath": "/ecs/linkedin-sim/minio"
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "mysql",
      "image": "__MYSQL_IMAGE__",
      "memoryReservation": 768,
      "essential": true,
      "environment": [
        {
          "name": "MYSQL_ROOT_PASSWORD",
          "value": "root"
        },
        {
          "name": "MYSQL_DATABASE",
          "value": "linkedin_sim"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "mysql-data",
          "containerPath": "/var/lib/mysql",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/linkedin-sim",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "mysql"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "mysqladmin ping -h127.0.0.1 -uroot -p$MYSQL_ROOT_PASSWORD --silent"
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 10,
        "startPeriod": 180
      }
    },
    {
      "name": "mongo",
      "image": "__MONGO_IMAGE__",
      "memoryReservation": 768,
      "essential": true,
      "mountPoints": [
        {
          "sourceVolume": "mongo-data",
          "containerPath": "/data/db",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/linkedin-sim",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "mongo"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "mongosh --quiet --eval \"db.adminCommand('ping').ok\" | grep 1"
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 10,
        "startPeriod": 120
      }
    },
    {
      "name": "redis",
      "image": "redis:7",
      "memoryReservation": 128,
      "essential": true,
      "mountPoints": [
        {
          "sourceVolume": "redis-data",
          "containerPath": "/data",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/linkedin-sim",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "redis"
        }
      },
      "healthCheck": {
        "command": [
          "CMD",
          "redis-cli",
          "ping"
        ],
        "interval": 10,
        "timeout": 3,
        "retries": 10,
        "startPeriod": 30
      }
    },
    {
      "name": "kafka",
      "hostname": "kafka",
      "image": "apache/kafka:4.2.0",
      "memoryReservation": 1536,
      "essential": true,
      "environment": [
        {
          "name": "KAFKA_NODE_ID",
          "value": "1"
        },
        {
          "name": "KAFKA_PROCESS_ROLES",
          "value": "broker,controller"
        },
        {
          "name": "KAFKA_LISTENERS",
          "value": "PLAINTEXT://:9092,CONTROLLER://:9093"
        },
        {
          "name": "KAFKA_ADVERTISED_LISTENERS",
          "value": "PLAINTEXT://kafka:9092"
        },
        {
          "name": "KAFKA_CONTROLLER_LISTENER_NAMES",
          "value": "CONTROLLER"
        },
        {
          "name": "KAFKA_LISTENER_SECURITY_PROTOCOL_MAP",
          "value": "PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT"
        },
        {
          "name": "KAFKA_CONTROLLER_QUORUM_VOTERS",
          "value": "1@kafka:9093"
        },
        {
          "name": "KAFKA_INTER_BROKER_LISTENER_NAME",
          "value": "PLAINTEXT"
        },
        {
          "name": "KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR",
          "value": "1"
        },
        {
          "name": "KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR",
          "value": "1"
        },
        {
          "name": "KAFKA_TRANSACTION_STATE_LOG_MIN_ISR",
          "value": "1"
        },
        {
          "name": "KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS",
          "value": "0"
        },
        {
          "name": "KAFKA_AUTO_CREATE_TOPICS_ENABLE",
          "value": "true"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "kafka-data",
          "containerPath": "/var/lib/kafka/data",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/linkedin-sim",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "kafka"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "/opt/kafka/bin/kafka-topics.sh --bootstrap-server kafka:9092 --list >/dev/null 2>&1"
        ],
        "interval": 20,
        "timeout": 10,
        "retries": 15,
        "startPeriod": 120
      }
    },
    {
      "name": "minio",
      "image": "minio/minio:latest",
      "memoryReservation": 256,
      "essential": true,
      "command": [
        "server",
        "/data",
        "--console-address",
        ":9001"
      ],
      "environment": [
        {
          "name": "MINIO_ROOT_USER",
          "value": "minioadmin"
        },
        {
          "name": "MINIO_ROOT_PASSWORD",
          "value": "minioadmin"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "minio-data",
          "containerPath": "/data",
          "readOnly": false
        }
      ],
      "portMappings": [
        {
          "containerPort": 9000,
          "hostPort": 9000,
          "protocol": "tcp"
        },
        {
          "containerPort": 9001,
          "hostPort": 9001,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/linkedin-sim",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "minio"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -fsS http://127.0.0.1:9000/minio/health/live >/dev/null"
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 10,
        "startPeriod": 60
      }
    },
    {
      "name": "auth_service",
      "image": "__BACKEND_IMAGE__",
      "memoryReservation": 512,
      "essential": true,
      "command": [
        "uvicorn",
        "services.auth_service.app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8001"
      ],
      "environment": [
        {
          "name": "EVENT_BUS_MODE",
          "value": "kafka"
        },
        {
          "name": "KAFKA_BOOTSTRAP_SERVERS",
          "value": "kafka:9092"
        },
        {
          "name": "CACHE_MODE",
          "value": "redis"
        },
        {
          "name": "REDIS_URL",
          "value": "redis://redis:6379/0"
        },
        {
          "name": "MYSQL_HOST",
          "value": "mysql"
        },
        {
          "name": "MYSQL_PORT",
          "value": "3306"
        },
        {
          "name": "MYSQL_DATABASE",
          "value": "linkedin_sim"
        },
        {
          "name": "MYSQL_USER",
          "value": "root"
        },
        {
          "name": "MYSQL_PASSWORD",
          "value": "root"
        },
        {
          "name": "MONGO_URL",
          "value": "mongodb://mongo:27017"
        },
        {
          "name": "MONGO_DATABASE",
          "value": "linkedin_sim_docs"
        },
        {
          "name": "MINIO_ENDPOINT",
          "value": "minio:9000"
        },
        {
          "name": "MINIO_PUBLIC_ENDPOINT",
          "value": "__APP_HOST__:9000"
        },
        {
          "name": "MINIO_ROOT_USER",
          "value": "minioadmin"
        },
        {
          "name": "MINIO_ROOT_PASSWORD",
          "value": "minioadmin"
        },
        {
          "name": "MINIO_BUCKET_PROFILE",
          "value": "profile-media"
        },
        {
          "name": "MINIO_BUCKET_RESUME",
          "value": "resume-media"
        },
        {
          "name": "MINIO_SECURE",
          "value": "false"
        },
        {
          "name": "APP_VERSION",
          "value": "1.0.0"
        },
        {
          "name": "JWT_ISSUER",
          "value": "owner1-auth"
        },
        {
          "name": "JWT_AUDIENCE",
          "value": "linkedin-clone"
        },
        {
          "name": "OWNER1_JWKS_URL",
          "value": "http://auth_service:8001/.well-known/jwks.json"
        },
        {
          "name": "SERVICE_NAME",
          "value": "auth_service"
        }
      ],
      "portMappings": [
        {
          "containerPort": 8001,
          "hostPort": 8001,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/linkedin-sim",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "auth_service"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8001/ops/healthz', timeout=2)\""
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 10,
        "startPeriod": 120
      },
      "links": [
        "mysql",
        "mongo",
        "redis",
        "kafka",
        "minio"
      ],
      "dependsOn": [
        {
          "containerName": "mysql",
          "condition": "HEALTHY"
        },
        {
          "containerName": "mongo",
          "condition": "HEALTHY"
        },
        {
          "containerName": "redis",
          "condition": "HEALTHY"
        },
        {
          "containerName": "kafka",
          "condition": "HEALTHY"
        }
      ]
    },
